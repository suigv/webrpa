{
  "detect": {
    "action": "core.detect_login_stage",
    "params": {
      "package": "com.example.app",
      "stage_order": ["captcha", "two_factor", "password", "account", "login_entry", "home"],
      "stage_patterns": {
        "login_entry": {
          "text_markers": ["登录", "Log in"],
          "resource_ids": ["com.example.app:id/login"]
        },
        "home": {
          "text_markers": ["首页", "Home"],
          "resource_ids": ["com.example.app:id/home_tab"]
        }
      }
    }
  },
  "wait": {
    "action": "core.wait_login_stage",
    "params": {
      "package": "com.example.app",
      "target_stages": ["home"],
      "timeout_ms": 20000,
      "interval_ms": 800
    }
  }
}
