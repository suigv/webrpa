{
  "app_package": "com.example.app",
  "xml_filter": {
    "max_text_len": 60,
    "max_desc_len": 100
  },
  "states": [
    {
      "state_id": "home",
      "anchors": {
        "text_contains": ["首页", "Home"],
        "resource_id_contains": ["id/home", "id/feed"]
      }
    },
    {
      "state_id": "login_entry",
      "anchors": {
        "text_contains": ["登录", "Log in"],
        "resource_id_contains": ["id/login"]
      }
    }
  ]
}
