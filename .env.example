# WebRPA 环境变量配置示例 (.env.example)
# 复制此文件为 .env 并根据需要修改
# 使用 MYT_LOAD_DOTENV=1 启动程序以加载此文件

# ─── 核心服务配置 ───────────────────────────────────────
# API 服务监听地址和端口
MYT_API_HOST=127.0.0.1
MYT_API_PORT=8001

# 是否加载 .env 文件 (1=加载, 0=忽略)
MYT_LOAD_DOTENV=1

# 任务队列后端 (redis 或 memory)
# 开发模式建议使用 memory，生产环境必须使用 redis
MYT_TASK_QUEUE_BACKEND=redis


# ─── LLM / 大模型 API 密钥 (Secrets) ───────────────────
# 全局通用 LLM API Key (兜底)
MYT_LLM_API_KEY=sk-your-global-key

# 特定服务商 API Key (优先级最高)
# 格式: MYT_LLM_API_KEY_{PROVIDER_UPPER}
MYT_LLM_API_KEY_DEEPSEEK=sk-your-deepseek-key
MYT_LLM_API_KEY_OPENAI=sk-your-openai-key
MYT_LLM_API_KEY_SILICONFLOW=sk-your-siliconflow-key


# ─── VLM / 视觉大模型 (UI-TARS) ──────────────────────
# 全局 VLM API Key (兜底 / 兼容旧版)
UITARS_API_KEY=your-uitars-key

# 特定视觉服务商 API Key
# 格式: MYT_VLM_API_KEY_{PROVIDER_UPPER}
MYT_VLM_API_KEY_UITARS=your-uitars-specific-key


# ─── 任务执行与调度策略 ────────────────────────────────
# 最大并发任务数 (默认 32)
MYT_MAX_CONCURRENT_TASKS=32

# 僵尸任务判定阈值 (秒, 默认 300)
# 超过此时间未更新心跳的任务将被强制标记为待恢复或失败
MYT_TASK_STALE_RUNNING_SECONDS=300

# 任务强制杀停等待时间 (秒)
MYT_TASK_CANCEL_GRACE_SECONDS=5
MYT_TASK_FORCE_KILL_SECONDS=10


# ─── 硬件与核心逻辑开关 ────────────────────────────────
# 是否启用硬件 RPC 通道 (1=开启, 0=关闭/Web开发模式)
# 在没有 Android 设备的环境下开发 Web 自动化建议设为 0
MYT_ENABLE_RPC=1

# 默认 App 配置名 (用于未指定 package 时的配置读取)
MYT_DEFAULT_APP=default

# 严格模式：拒绝插件中未定义的输入参数 (1=开启, 0=关闭)
MYT_STRICT_PLUGIN_UNKNOWN_INPUTS=1


# ─── 路径与底层覆盖 (通常无需修改) ─────────────────────
# 强制指定项目根目录 (如果自动识别失效)
# MYT_NEW_ROOT=/path/to/webrpa

# 强制指定原生库 libmytrpc 路径
# MYT_RPC_LIB_PATH=/path/to/libs

# 运行性能调优 (仅对 Redis 队列有效)
# MYT_QUEUE_AGING_INTERVAL=120
# MYT_QUEUE_AGING_BOOST=10
